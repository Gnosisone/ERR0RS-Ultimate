# ERR0RS-Ultimate — git line ending policy
# Only enforce on source files — exclude flipper SD content

# Source files: always LF
*.py        text eol=lf
*.sh        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.json      text eol=lf

# Binary — never touch line endings
*.pdf       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.ico       binary
*.db        binary
*.bin       binary

# Flipper SD content — preserve as-is (mixed Windows/Linux sources)
src/output/flipper_sd/**  -text
