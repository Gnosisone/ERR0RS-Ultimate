# ═══════════════════════════════════════════════
# ERR0RS-Ultimate — .gitignore
# ═══════════════════════════════════════════════

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.spec

# Virtual environments
venv/
.venv/
env/
.env/

# Environment files (never commit secrets)
.env
.env.*
!configs/config.template.env

# Database
errors.db
*.db
*.sqlite
*.sqlite3

# Logs
*.log
hailort.log
logs/

# Reports (generated output — not source)
reports/
output/credentials/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover

# Secrets / keys
*.pem
*.key
*.crt
*.pfx
secrets/
credentials/

# Node (dashboard deps if added later)
node_modules/
npm-debug.log*

# Kali / Pi specific
*.img
*.iso

# ChromaDB runtime data
errors_knowledge_db/*.sqlite3-shm
errors_knowledge_db/*.sqlite3-wal
errors.db-shm
errors.db-wal
errors_knowledge_db/*/
errors_knowledge_db/*.sqlite3
