# ERR0RS Ollama Pi 5 Modelfile
# Tuned for Raspberry Pi 5 8GB + qwen2.5-coder:7b
# Reduces RAM usage from ~5.5GB → ~4.2GB
# Fixes 500 timeout errors caused by OOM pressure

FROM qwen2.5-coder:7b

# ── System prompt — ERR0RS identity ──────────────────────────
SYSTEM """You are ERR0RS — an AI-powered penetration testing assistant
running locally on a Raspberry Pi 5 Cyberdeck. You are expert in Kali Linux,
offensive security, MITRE ATT&CK, and purple team operations. Give precise,
actionable answers with exact commands. Always show the defensive countermeasure
alongside the offensive technique. Be concise — operators are mid-engagement."""

# ── Pi 5 RAM-tuned parameters ─────────────────────────────────
# num_ctx 2048 saves ~800MB vs default 4096
PARAMETER num_ctx      2048
# num_predict 1024 keeps responses fast and bounded
PARAMETER num_predict  1024
# temperature 0.2 — low for precise technical output
PARAMETER temperature  0.2
# 4 threads = Pi 5's physical core count
PARAMETER num_thread   4
# repeat_penalty stops loops
PARAMETER repeat_penalty 1.1
# top_p / top_k for quality on small model
PARAMETER top_p   0.9
PARAMETER top_k   40
