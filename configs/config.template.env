# ============================================================
# ERR0RS ULTIMATE — Configuration Template
# Copy this file to .env in the project root and fill in values
# Run: cp configs/config.template.env .env
# ============================================================

# ── AI BACKEND ───────────────────────────────────────────────
# Choose your LLM backend: ollama | anthropic | openai
LLM_BACKEND=ollama

# Ollama (local, fully offline — recommended for client work)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Cloud API keys (optional — leave blank to use Ollama only)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── WEB UI ───────────────────────────────────────────────────
UI_HOST=127.0.0.1
UI_PORT=8765

# ── DATABASE (optional — for engagement memory) ──────────────
DB_URL=postgresql://errorz:err0rs_secure@localhost/errorz
REDIS_URL=redis://localhost:6379

# ── SECURITY ─────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_replace_with_generated_key

# ── HARDWARE FLAGS (auto-detected at runtime) ─────────────────
HAILO_ENABLED=false
PI5_MODE=false

# ── DISTRO (auto-set by install.sh) ──────────────────────────
DISTRO=kali

# ── ENGAGEMENT DEFAULTS ──────────────────────────────────────
DEFAULT_SCOPE=
DEFAULT_REPORT_FORMAT=html
TEACH_MODE=false
